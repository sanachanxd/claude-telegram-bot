telegram:
  bot_token: ""  # 从 @BotFather 获取，或设置环境变量 TELEGRAM_BOT_TOKEN
  allowed_user_ids:
    - 0  # 你的 Telegram User ID，从 @userinfobot 获取

proxy:
  host: "127.0.0.1"
  port: 10808
  type: "http"

claude:
  default_mode: "acceptEdits"  # plan / acceptEdits / bypassPermissions
  timeout: 300
  default_cwd: "~"

projects:
  path_blacklist:
    - "/usr"
    - "/etc"
    - "/System"
    - "/Library"
    - "/bin"
    - "/sbin"

models:
  default: "claude-sonnet-4-6"
  available:
    - name: "sonnet"
      id: "claude-sonnet-4-6"
      desc: "Sonnet 4.6 快速"
    - name: "opus"
      id: "claude-opus-4-7"
      desc: "Opus 4.7 最强"
    - name: "haiku"
      id: "claude-haiku-4-5-20251001"
      desc: "Haiku 4.5 轻量"
